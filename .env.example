# Copy to `.env` for local dev. Never commit secrets.

# Optional — use when you add Maps/Places in this app (Store Locations UI is form-only today).
# Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=

# Geocoding API (HTTP) / server-side
VITE_GOOGLE_GEOCODING_API_KEY=

# Places API (e.g. address autocomplete)
VITE_GOOGLE_PLACES_API_KEY=

# Use on the server: Directions API, Distance Matrix API (avoid exposing in the browser)
# GOOGLE_DIRECTIONS_API_KEY=
# GOOGLE_DISTANCE_MATRIX_API_KEY=
